{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/save.py", "use": "@vercel/python" },
    { "src": "api/load.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/save", "dest": "/api/save.py" },
    { "src": "/api/load", "dest": "/api/load.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
